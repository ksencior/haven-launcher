{
  "name": "havenlauncher",
  "version": "0.6.3-beta",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "node build-script.js"
  },
  "keywords": [],
  "author": "ksendev",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2",
    "minecraft-server-util": "^5.4.4",
    "msmc": "^5.0.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ksencior.havenlauncher",
    "productName": "HavenLauncher",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon.png",
      "category": "Game"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!.env"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ksencior",
        "repo": "haven-launcher"
      }
    ]
  }
}
